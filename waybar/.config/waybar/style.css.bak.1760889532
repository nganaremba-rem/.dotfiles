@import "../omarchy/current/theme/waybar.css";

@define-color bg-color #2D2439;

* {
  /*  background-color: @background; */
  color: @foreground;

  border: none;
  border-radius: 10px;
  min-height: 0;
  font-family: "JetBrainsMono Nerd Font";
  font-size: 15px;
}

#waybar {
  background-color: transparent;
}

.modules-left {
  margin-left: 8px;
  background-color: @bg-color;
  padding: 3px 10px;
}

.modules-center {
  background-color: @bg-color;
  padding: 3px 10px;
}

.modules-right {
  margin-right: 8px;
  background-color: @bg-color;
  padding: 3px 10px;
}

#workspaces button {
  all: initial;
  padding: 0 6px;
  margin: 0 1.5px;
  min-width: 9px;
}

#workspaces button.active {
  background-color: #c65c5c;
  border-radius: 10px;
}

#workspaces button.empty {
  opacity: 0.5;
}

#tray,
#cpu,
#battery,
#network,
#bluetooth,
#pulseaudio,
#custom-omarchy,
#custom-screenrecording-indicator,
#custom-update {
  min-width: 12px;
  margin: 0 10px;
}

#custom-expand-icon {
  margin-right: 7px;
}

tooltip {
  padding: 2px;
  background-color: @bg-color;
}

#custom-update {
  font-size: 10px;
}

#clock {
  margin-left: 8.75px;
}

.hidden {
  opacity: 0;
}

#custom-screenrecording-indicator {
  min-width: 12px;
  margin-left: 8.75px;
  font-size: 10px;
}

#custom-screenrecording-indicator.active {
  color: #a55555;
}
